anthias-server:
    image: ghcr.io/screenly/anthias-server:latest-x86
    ports:
      - "80:80"
    environment:
      - HOME=/data
      - LISTEN=0.0.0.0
      - CELERY_BROKER_URL=redis://redis:6379/0
      - CELERY_RESULT_BACKEND=redis://redis:6379/0
    depends_on:
      - redis
    restart: always
    volumes:
      - ./data:/data
    mem_limit: 512m
